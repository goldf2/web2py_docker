# Copy these values into Coolify environment variables or into a local .env file.

# Coolify may inject PORT automatically. Keep 8000 for local Docker Compose.
PORT=8000

# Optional: set this to enable the web2py admin app.
# Use HTTPS when accessing /admin remotely; web2py disables admin on insecure remote HTTP.
# WEB2PY_ADMIN_PASSWORD=change-me

# Optional: root directory for app runtime data inside the container.
# Mount host persistent storage, for example /opt/web2py, to this container path.
# WEB2PY_RUNTIME_ROOT=/app/runtime

# Optional: built-in apps should stay inside the image and not use runtime symlinks.
# WEB2PY_RUNTIME_SKIP_APPS=admin welcome

# Optional: soloj1 symlink test target. Mount persistent storage here in Coolify
# when testing host storage as a symlink destination inside the container.
# SOLOJ1_EXTERNAL_LINK_TARGET=/app/runtime/soloj1-external-target

# Optional: set this only if your app uses Google Cloud Firestore credentials.
# In production, prefer Coolify secrets or a mounted file instead of committing credentials.
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-service-account.json

# Optional: set this if your application code reads a Google Cloud project id.
# GOOGLE_CLOUD_PROJECT=your-project-id
