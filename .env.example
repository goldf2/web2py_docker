# Copy these values into Coolify environment variables or into a local .env file.

# Coolify may inject PORT automatically. Keep 8000 for local Docker Compose.
PORT=8000

# Optional: set this only if your app uses Google Cloud Firestore credentials.
# In production, prefer Coolify secrets or a mounted file instead of committing credentials.
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-service-account.json

# Optional: set this if your application code reads a Google Cloud project id.
# GOOGLE_CLOUD_PROJECT=your-project-id
