# Copy these values into Coolify environment variables or a local .env file.

# Coolify may inject PORT automatically. Keep 8000 for local Docker Compose.
PORT=8000

# Optional: set these only if your app uses Google Cloud or Firestore credentials.
# Prefer Coolify secrets or mounted files instead of committing credentials.
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-service-account.json
# GOOGLE_CLOUD_PROJECT=your-project-id
